  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["k8s-postgresql-operator"],
      "targetBlank": true,
      "title": "K8s PG Operator Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
